{
  "name": "spt-ui-lib",
  "private": false,
  "license": "MIT",
  "keywords": [
    "spring boot",
    "react",
    "persistent tasks",
    "jobs ui",
    "job dashboard",
    "ui",
    "lib"
  ],
  "version": "2.3.1",
  "type": "module",
  "composite": true,
  "outDir": "dist",
  "jsx": "react-jsx",
  "strict": true,
  "main": "./dist/main.umd.cjs",
  "module": "./dist/main.js",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js",
      "require": "./dist/main.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest"
  },
  "dependencies": {
    "@uiw/react-json-view": "2.0.0-alpha.40",
    "axios": "^1.13.2",
    "bootstrap": "^5.3.8",
    "react-bootstrap": "^2.10.10",
    "react-bootstrap-icons": "^1.11.6"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^25.0.6",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.0.0",
    "jsdom": "^27.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.52.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.16"
  }
}
